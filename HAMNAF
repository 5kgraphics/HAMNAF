<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Links</title>
    <style>
        :root {
            --bg-color: #f3f4f6;
            --button-bg: #ffffff;
            --button-hover: #e5e7eb;
            --text-color: #1f2937;
            --shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            background-color: var(--bg-color);
            color: var(--text-color);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            margin: 0;
            padding: 20px;
        }

        .container {
            width: 100%;
            max-width: 480px;
            text-align: center;
        }

        .profile-img {
            width: 96px;
            height: 96px;
            background-color: #ccc;
            border-radius: 50%;
            margin-bottom: 1rem;
            display: inline-block;
        }

        h1 {
            font-size: 1.25rem;
            font-weight: 700;
            margin-bottom: 2rem;
        }

        .links-wrapper {
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .link-button {
            display: block;
            background-color: var(--button-bg);
            color: var(--text-color);
            text-decoration: none;
            padding: 16px;
            border-radius: 8px;
            font-weight: 600;
            transition: all 0.2s ease;
            box-shadow: var(--shadow);
            border: 1px solid transparent;
        }

        .link-button:hover {
            background-color: var(--button-hover);
            transform: translateY(-2px);
        }

        .link-button:active {
            transform: translateY(0);
        }
    </style>
</head>
<body>

    <div class="container">
        <div class="profile-img"></div>
        <h1>HAMNAF TAILORING</h1>

        <div class="links-wrapper">
            <a href="https://drive.google.com/file/d/1K5Q8xhwFsIqNDH2sL9I5GKmlzVLuDjkK/view?usp=drive_linkhttps://drive.google.com/file/d/1K5Q8xhwFsIqNDH2sL9I5GKmlzVLuDjkK/view?usp=drive_link" class="link-button" target="_blank">
                DESGN 1
            </a>
            
            <a href="https://drive.google.com/file/d/1fOf8vBKvJ_LoTOohnkpZyHfKalHZN8PP/view?usp=drive_link" class="link-button" target="_blank">
                DESIGN 2
            </a>
        </div>
    </div>

</body>
</html>
